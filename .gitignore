__pycache__/
*.py[cod]
*.pyo
.env

# Temp uploads and generated reports (user data, never commit)
temp_uploads/
reports/

# Project-specific override rules (may contain client data)
project_rules/*.xlsx
project_rules/*.xlsm
project_rules/*.csv
# Keep the auto-generated templates
!project_rules/false_positive_rules_TEMPLATE.xlsx
!project_rules/accepted_patterns_TEMPLATE.xlsx

# RAG embedding cache (rebuilt automatically from reference files)
.rag_cache/

# Streamlit secrets (never commit real keys)
.streamlit/secrets.toml

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
