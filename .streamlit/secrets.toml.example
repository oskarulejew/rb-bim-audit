# Copy this file structure into Streamlit Cloud → App settings → Secrets
# DO NOT commit secrets.toml itself — it is in .gitignore

# Your OpenAI API key (optional — enables AI reasoning review by default)
OPENAI_API_KEY = "sk-..."

# Comma-separated access codes. Anyone with one of these codes can sign in.
# Change or add codes at any time; the app reloads secrets on every run.
ACCESS_CODES = "esprii2025,bimaudit,rb-team"

# Comma-separated allowed email addresses (optional).
# If left empty, any email address works as long as the code is correct.
ALLOWED_EMAILS = "user@esprii.ee,colleague@company.com"
